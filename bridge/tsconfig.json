  "include": [
    "claude-agent-bridge.ts",
    "omp-bridge.ts",
    "compact-helpers.ts",
    "compact-helpers.test.ts",
    "agent-end-watchdog.ts",
    "agent-end-watchdog.test.ts",
    "types.d.ts"
  ]
}
